{
  "name": "@langfuse/claude-observability-plugin",
  "version": "3.0.0",
  "description": "Claude Code plugin that traces sessions, turns, generations, and tool calls to Langfuse",
  "keywords": [
    "claude-code",
    "claude",
    "anthropic",
    "langfuse",
    "observability",
    "tracing",
    "opentelemetry"
  ],
  "homepage": "https://langfuse.com/integrations/other/claude-code",
  "bugs": {
    "url": "https://github.com/langfuse/Claude-Observability-Plugin/issues"
  },
  "license": "MIT",
  "author": "Langfuse",
  "repository": {
    "type": "git",
    "url": "https://github.com/langfuse/Claude-Observability-Plugin.git"
  },
  "type": "module",
  "scripts": {
    "build": "bun build src/index.ts --outfile dist/index.mjs --target node --format esm",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:tsc": "tsc --noEmit",
    "lint:dist": "bun run build && git diff --exit-code -- dist/index.mjs",
    "lint": "bun run format:check && bun run lint:tsc && bun run lint:dist"
  },
  "dependencies": {
    "@langfuse/otel": "^5.4.1",
    "@langfuse/tracing": "^5.4.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": "^2.0.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.205.0",
    "@opentelemetry/sdk-trace-base": "^2.0.1",
    "@opentelemetry/sdk-trace-node": "^2.0.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^22.10.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "bun": ">=1.2"
  }
}
